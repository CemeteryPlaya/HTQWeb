VITE_API_BASE_URL="/api/"
# HTTPS mode for Vite dev server:
# - true  => force HTTPS when certs exist
# - false => force HTTP only for local debugging without tunnel
VITE_DEV_HTTPS=true
VITE_BACKEND_HTTP_TARGET="http://127.0.0.1:8000"
VITE_BACKEND_WS_TARGET="ws://127.0.0.1:8000"
VITE_SFU_WS_TARGET="ws://127.0.0.1:4443"
# Keep empty to use current origin + /ws/sfu/ (recommended for ngrok).
VITE_SFU_URL=""
# WebTransport endpoint for QUIC-based signaling (Variant B hybrid mode).
# When set AND the browser supports WebTransport, signaling uses QUIC instead
# of WebSocket. WebRTC media (ICE/DTLS/RTP) continues to work as before.
# Must be an https:// URL pointing to the aioquic proxy (port 4433 by default).
# Leave empty to use WebSocket signaling only (safe default).
#
# Local dev:  https://localhost:4433/sfu
# Production: https://your-domain.com:4433/sfu
#
# NOTE: The browser needs to trust the TLS certificate.
#       For local dev run: python backend/webtransport/generate_cert.py
#       and start Chrome with the printed --ignore-certificate-errors-spki-list flag.
VITE_WEBTRANSPORT_URL=""
# Optional tunnel helpers:
# - Set tunnel host to stabilize Vite HMR websocket over ngrok.
# - Or disable HMR completely during remote tests.
# VITE_TUNNEL_PUBLIC_HOST="your-subdomain.ngrok-free.app"
VITE_DISABLE_HMR=false
