# Copy to .env.development.local and adjust if services run on non-default ports.
# Vite dev server proxies /api/* to these targets — mirrors nginx upstream routing.

# Django backend (legacy API, websockets)
VITE_BACKEND_HTTP_TARGET=http://127.0.0.1:8000
VITE_BACKEND_WS_TARGET=ws://127.0.0.1:8000

# FastAPI microservices
VITE_HR_SERVICE_TARGET=http://127.0.0.1:8006
VITE_TASKS_SERVICE_TARGET=http://127.0.0.1:8007
VITE_USER_SERVICE_TARGET=http://127.0.0.1:8005

# SFU (mediasoup signaling)
VITE_SFU_WS_TARGET=ws://127.0.0.1:4443

# Set to false to force HTTP (faster dev start without cert lookup)
VITE_DEV_HTTPS=false
