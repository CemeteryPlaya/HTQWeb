VITE_API_BASE_URL="/api/"
VITE_DEV_HTTPS=true
# Keep empty for dynamic current-origin signaling (recommended with rotating ngrok domains).
VITE_SFU_URL=""
# WebTransport endpoint — leave empty to use WebSocket (default).
# Set to https://localhost:4433/sfu after running: python backend/webtransport/generate_cert.py
VITE_WEBTRANSPORT_URL=""
VITE_SFU_WS_TARGET="ws://127.0.0.1:4443"
# ngrok remote debugging: disable Vite HMR websocket noise in browser console.
VITE_DISABLE_HMR=true
# Set this to your ngrok domain (e.g. xyz.ngrok-free.app) to enable HMR
VITE_TUNNEL_PUBLIC_HOST=""
VITE_BACKEND_HTTP_TARGET="http://127.0.0.1"
VITE_BACKEND_WS_TARGET="ws://127.0.0.1"
