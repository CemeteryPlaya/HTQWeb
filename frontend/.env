VITE_API_BASE_URL="/api/"

# HTTP-only by default. Set VITE_DEV_HTTPS=true and provision certs in
# infra/certs/{cert.pem,key.pem} only when you need a secure context for
# WebRTC (mediasoup/SFU) or for LAN devices that won't accept ws:// from
# a non-localhost origin.
VITE_DEV_HTTPS=false

# Hot-module reload — turn off only if you're tunneling via ngrok and
# want to silence the WS reconnect spam.
VITE_DISABLE_HMR=false

# Mediasoup SFU upstream — empty disables /conference; set to the
# ws://host:port the SFU is listening on (default: ws://127.0.0.1:4443).
VITE_SFU_URL=""
VITE_SFU_WS_TARGET="ws://127.0.0.1:4443"

# WebTransport endpoint — leave empty to use WebSocket signalling (default).
# Set to https://localhost:4433/sfu after running:
#   python webtransport/generate_cert.py
VITE_WEBTRANSPORT_URL=""

# Tunnel-mode: set to your ngrok subdomain (e.g. xyz.ngrok-free.app) to
# pin Vite's HMR client to the tunnel. Leave empty for plain localhost dev.
VITE_TUNNEL_PUBLIC_HOST=""
