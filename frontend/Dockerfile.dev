FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache python3 make g++

COPY package.json package-lock.json ./
RUN npm ci --legacy-peer-deps --no-audit --no-fund

# Source is mounted as volume at runtime — COPY . . is intentionally omitted
# so host changes reflect without rebuilding the image.

EXPOSE 3000

CMD ["npm", "run", "dev"]
