# ─── Shared secrets (used by Django + all microservices) ─────────────────────
# Must match across: backend, user-service, hr-service, task-service
JWT_SECRET=change-me-to-a-random-256-bit-secret
SERVICE_ENV=production

# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (Postgres)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=htqweb
DB_USER=htqweb
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432
# Host port used to expose Docker Postgres for local Django (outside Docker)
DB_HOST_PORT=55432

# Cache (Redis)
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://redis:6379/0

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Conference / SFU
# Frontend reads this from backend endpoint: /api/v1/conference/config/
# Leave CONFERENCE_SFU_URL empty to use current origin + CONFERENCE_SFU_PATH (recommended).
CONFERENCE_SFU_URL=
CONFERENCE_SFU_PATH=/ws/sfu/

# SFU runtime (Node mediasoup service)
SFU_HOST=0.0.0.0
SFU_PORT=4443
SIGNALING_REQUIRE_TLS=true
TLS_CERT=./infra/certs/cert.pem
TLS_KEY=./infra/certs/key.pem
# mediasoup bitrate units are bps (bits per second):
# 6 Mbps = 6000000 (not 6000)
VIDEO_BITRATE_BPS=12000000
AUDIO_BITRATE_BPS=192000
WEBRTC_INITIAL_AVAILABLE_OUTGOING_BITRATE=12000000
WEBRTC_MAX_INCOMING_BITRATE=15000000

# Email (опционально)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
STAFF_NOTIFICATION_EMAILS=admin@yourdomain.com

# File Storage (S3 / MinIO) — по умолчанию local
STORAGE_BACKEND=local
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_STORAGE_BUCKET_NAME=htqweb-media
# AWS_S3_ENDPOINT_URL=http://minio:9000
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=
