# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Django
*.sqlite3
/backend/staticfiles/
/backend/media/

# ─── Environment / Secrets ───────────────────────────────────────────────────
# Keep .env.example (template), ignore actual .env files with real secrets
.env
.env.local
.env.*.local
!.env.example
!frontend/.env.example

# ─── TLS Certificates ────────────────────────────────────────────────────────
# Generated by backend/webtransport/generate_cert.py — never commit private keys
backend/webtransport/certs/

# ─── Frontend ────────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.env

# ─── Docker ──────────────────────────────────────────────────────────────────
# Nothing to ignore — docker-compose.yml and Dockerfiles are committed

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── pytest / coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
