# sfu/.env.tunnel.example (DO NOT COMMIT actual .env values)
#
# These are the variables injected by scripts/start-sfu-tunnel.ps1
# when running Mediasoup SFU in TCP-only mode over Cloudflare & Bore tunnels.

# The public IP of the TCP tunnel (e.g. resolved IP of bore.pub)
WEBRTC_ANNOUNCED_IP=144.202.62.247

# The external TCP port assigned by the bore.pub server
WEBRTC_SERVER_PORT=38192

# Tunnels cannot route UDP traffic (they are TCP proxies)
# These flags force TCP transport and disable UDP entirely.
WEBRTC_ENABLE_UDP=false
WEBRTC_ENABLE_TCP=true
WEBRTC_PREFER_UDP=false
WEBRTC_PREFER_TCP=true
TCP_TUNNEL_MODE=true

# TLS is offloaded by Cloudflare Tunnel at the edge
SIGNALING_REQUIRE_TLS=false

# Disable origin checks because Cloudflare Tunnel URL is dynamic
SIGNALING_DISABLE_ORIGIN_CHECK=true
SIGNALING_ALLOW_NO_ORIGIN=true
