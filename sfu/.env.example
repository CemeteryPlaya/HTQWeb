# ── SFU Server Configuration ──

# Server
SFU_PORT=4443
SFU_HOST=::

# TLS (for WSS signaling)
TLS_CERT=/etc/ssl/certs/fullchain.pem
TLS_KEY=/etc/ssl/private/privkey.pem

# Signaling WS Upgrade validation
SIGNALING_REQUIRE_TLS=true
# Include "/" for reverse proxies that strip "/ws/sfu/" prefix via trailing slash in proxy_pass.
SIGNALING_WS_PATHS=/,/ws/sfu,/ws/sfu/
SIGNALING_DISABLE_ORIGIN_CHECK=false
SIGNALING_ALLOWED_ORIGINS=https://*.instatunnel.my,https://conference.example.com
SIGNALING_ALLOW_NO_ORIGIN=true

# Mediasoup Workers
# Number of workers = CPU cores (0 = auto-detect)
MEDIASOUP_WORKERS=1

# WebRTC listen IPs
# !! WEBRTC_ANNOUNCED_IP is REQUIRED when listen IP is 0.0.0.0 or ::
# !! Server will REFUSE to start (fatal error) if announcedIp is missing.
# Set WEBRTC_ANNOUNCED_IP to your LAN IP or public IP.
WEBRTC_LISTEN_IPS=0.0.0.0
WEBRTC_ANNOUNCED_IP=YOUR_LAN_OR_PUBLIC_IP

# WebRTC transport protocols (strict NAT/tunnel friendly defaults)
WEBRTC_ENABLE_UDP=true
WEBRTC_ENABLE_TCP=true
WEBRTC_PREFER_UDP=false
WEBRTC_PREFER_TCP=true
# When false, mediasoup will not emit extra local/private ICE candidates
# when announcedAddress is set.
WEBRTC_EXPOSE_INTERNAL_IP=false
# IMPORTANT: all bitrate values are in bps (bits per second), not kbps.
# Example: 6 Mbps = 6000000, not 6000.
WEBRTC_INITIAL_AVAILABLE_OUTGOING_BITRATE=12000000
WEBRTC_MAX_INCOMING_BITRATE=15000000

# Single-port WebRtcServer (replaces RTC_MIN_PORT/RTC_MAX_PORT range)
# Open this ONE port (TCP + UDP) in your firewall/router.
# This is required for Windows compatibility and NAT traversal.
WEBRTC_SERVER_PORT=44444

# TURN server (coturn)
TURN_URL=turn:turn.example.com:3478
TURN_URLS=turn:turn.example.com:443?transport=tcp,turns:turn.example.com:443?transport=tcp
TURN_USERNAME=htqweb
TURN_CREDENTIAL=your_turn_secret

# Target bitrates
# IMPORTANT: mediasoup expects bps.
VIDEO_BITRATE_BPS=12000000
AUDIO_BITRATE_BPS=192000

# BWE Override
BWE_INTERVAL_MS=50
BWE_SAFETY_FACTOR=0.85
BWE_PLR_THRESHOLD=0.03
