# ========================================
# SFU Server Configuration
# ========================================
# Скопируйте этот файл в sfu/.env и настройте под ваш сервер
# ========================================

# ── Сервер ──────────────────────────────────────────
# Порт для WebSocket signaling (должен быть открыт в firewall)
SFU_PORT=4443

# Хост для прослушивания (0.0.0.0 = все интерфейсы)
SFU_HOST=0.0.0.0

# ── TLS/SSL ─────────────────────────────────────────
# Для работы камеры/микрофона нужен HTTPS!
# Для тестов используйте ngrok/instatunnel для HTTPS туннеля
# Для production получите реальные сертификаты (Let's Encrypt)

# TLS_CERT=certs/cert.pem
# TLS_KEY=certs/key.pem

# ── WebRTC Network ──────────────────────────────────
# КРИТИЧЕСКИ ВАЖНО для работы видео между компьютерами!

# IP для прослушивания (0.0.0.0 = слушать все интерфейсы)
WEBRTC_LISTEN_IP=0.0.0.0

# ПУБЛИЧНЫЙ IP вашего сервера (обязательно для работы через интернет!)
# Для LAN: используйте локальный IP (например 192.168.1.100)
# Для интернета: используйте публичный IP сервера
# Узнать публичный IP: curl ifconfig.me
WEBRTC_ANNOUNCED_IP=

# Порт для WebRTC медиа (должен быть открыт в firewall!)
# Откройте UDP и TCP для максимальной совместимости
WEBRTC_SERVER_PORT=44444

# Если используете NAT/port forwarding, укажите внешний порт
# WEBRTC_ANNOUNCED_PORT=44444

# ── WebRTC Transport ───────────────────────────────
# Протоколы для WebRTC (для обычных настроек оставьте оба включенными)
WEBRTC_ENABLE_UDP=true
WEBRTC_ENABLE_TCP=true

# Для TCP_TUNNEL_MODE (ngrok, bore и т.д.) установите:
# TCP_TUNNEL_MODE=true
# WEBRTC_ENABLE_UDP=false
# WEBRTC_ENABLE_TCP=true

# Начальный битрейт (можно настроить позже)
WEBRTC_INITIAL_AVAILABLE_OUTGOING_BITRATE=1500000
WEBRTC_MAX_INCOMING_BITRATE=1875000

# ── Media Codecs ────────────────────────────────────
# Битрейт для видео и аудио
VIDEO_BITRATE_BPS=1500000
AUDIO_BITRATE_BPS=64000

# ── TURN Server ─────────────────────────────────────
# TURN сервер критически важен для работы через интернет (за NAT)!
# Без TURN видео не будет работать между разными сетями.

# Вариант 1: Публичный TURN (Twilio, Metered и т.д.)
# TURN_URLS=turn:global.turn.twilio.com:3478?transport=udp,turns:global.turn.twilio.com:443?transport=tcp
# TURN_USERNAME=your_twilio_username
# TURN_CREDENTIAL=your_twilio_password

# Вариант 2: Свой TURN сервер (coturn)
# TURN_URLS=turn:your_server_ip:3478?transport=udp,turns:your_server_ip:443?transport=tcp
# TURN_USERNAME=your_username
# TURN_CREDENTIAL=your_password

# Для LAN тестов TURN не требуется (закомментируйте выше)

# ── Mediasoup Workers ──────────────────────────────
# Количество рабочих процессов (обычно = количеству CPU ядер)
# Для начала оставьте 0 (автоматически)
MEDIASOUP_WORKERS=0

# ── BWE (Bandwidth Estimation) ─────────────────────
# Можно оставить по умолчанию
BWE_INTERVAL_MS=50
BWE_SAFETY_FACTOR=0.85
BWE_PLR_THRESHOLD=0.03
BWE_DEGRADED_BITRATE_BPS=8000000

# ── Signaling ──────────────────────────────────────
# Для тестов можно отключить проверку origin
SIGNALING_DISABLE_ORIGIN_CHECK=true
SIGNALING_ALLOW_NO_ORIGIN=true

# WebSocket пути (не меняйте если не уверены)
SIGNALING_WS_PATHS=/ws/sfu,/ws/sfu/

# Для production включите TLS и настройте разрешенные origins
# SIGNALING_REQUIRE_TLS=true
# SIGNALING_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── TCP Tunnel Mode ────────────────────────────────
# Включите ТОЛЬКО если используете TCP туннель (ngrok, bore и т.д.)
# TCP_TUNNEL_MODE=false
