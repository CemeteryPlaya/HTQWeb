# ── SFU Server Configuration (Local Development) ──

# Server
SFU_PORT=4443
SFU_HOST=::

# TLS — disabled for tunnel mode (instatunnel terminates TLS at the edge).
# For direct LAN TLS access, restore paths: TLS_CERT=../certs/cert.pem, TLS_KEY=../certs/key.pem
TLS_CERT=
TLS_KEY=

# Allow non-TLS WebSocket connections (tunnel sends plain WS)
SIGNALING_REQUIRE_TLS=false
# Include "/" for reverse proxies that strip "/ws/sfu/" prefix via trailing slash in proxy_pass.
SIGNALING_WS_PATHS=/,/ws/sfu,/ws/sfu/
SIGNALING_DISABLE_ORIGIN_CHECK=true
SIGNALING_ALLOWED_ORIGINS=https://*.instatunnel.my,http://*.instatunnel.my
SIGNALING_ALLOW_NO_ORIGIN=true

# Mediasoup Workers (0 = auto-detect CPU cores)
MEDIASOUP_WORKERS=1

# WebRTC listen IPs
# !! WEBRTC_ANNOUNCED_IP is REQUIRED when listen IP is 0.0.0.0 or ::
# !! Without it the server will refuse to start (fatal validation error)
# !! Set to your LAN IP (e.g. 192.168.1.100) or public IP for internet access
WEBRTC_LISTEN_IPS=0.0.0.0
WEBRTC_ANNOUNCED_IP=192.168.2.106
WEBRTC_ENABLE_UDP=true
WEBRTC_ENABLE_TCP=true
WEBRTC_PREFER_UDP=true
WEBRTC_PREFER_TCP=false
WEBRTC_EXPOSE_INTERNAL_IP=false
WEBRTC_INITIAL_AVAILABLE_OUTGOING_BITRATE=1500000
WEBRTC_MAX_INCOMING_BITRATE=1875000

# Single-port WebRtcServer (replaces RTC_MIN_PORT/RTC_MAX_PORT range)
# Open this SINGLE port (TCP + UDP) in Windows Firewall / router
# Much more reliable under Windows/WSL than a 1000-port range
WEBRTC_SERVER_PORT=44444

# TURN (TCP/TLS on 443 is required for restrictive NAT/tunnel paths)
# DISABLED: turn.example.com is a placeholder — the client wastes ICE gathering
# time on DNS failures. For LAN-only testing leave these commented. For internet
# access, set real coturn URL/credentials (see sfu/turnserver.conf).
#TURN_URLS=turn:turn.example.com:443?transport=tcp,turns:turn.example.com:443?transport=tcp
#TURN_USERNAME=htqweb
#TURN_CREDENTIAL=your_turn_secret

# Target bitrates
VIDEO_BITRATE_BPS=1500000
AUDIO_BITRATE_BPS=64000

# BWE Override
BWE_INTERVAL_MS=50
BWE_SAFETY_FACTOR=0.85
BWE_PLR_THRESHOLD=0.03
