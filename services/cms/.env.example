# ─── Service Identity ───────────────────────────────────────────────────────
SERVICE_NAME=cms
SERVICE_PORT=8008
SERVICE_ENV=development

# ─── JWT Authentication ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-django-secret-key
JWT_ALGORITHM=HS256
JWT_ISSUER=htqweb-auth

# ─── Database ───────────────────────────────────────────────────────────────
DB_HOST=pgbouncer
DB_PORT=5432
DB_NAME=htqweb
DB_USER=htqweb
DB_PASSWORD=change-me
DB_SCHEMA=cms

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Observability ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=cms
LOG_LEVEL=INFO

# ─── CMS-specific ──────────────────────────────────────────────────────────
CONFERENCE_CONFIG_PATH=app/data/conference.yaml
# TODO: set a real API key once the translation provider is chosen.
TRANSLATION_API_KEY=
TRANSLATION_PROVIDER=google
CONTACT_REQUEST_RATE_LIMIT=3/minute
EMAIL_SERVICE_URL=http://email-service:8011
AUDIT_LOG_RETENTION_DAYS=90

# ─── Legacy Django Fallback (for migration period) ─────────────────────────
LEGACY_BACKEND_URL=http://backend:8000
