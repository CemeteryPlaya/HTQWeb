# Task Service Environment Variables
# Copy to .env and fill in values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=htqweb
DB_USER=htqweb
DB_PASSWORD=change-me
DB_SCHEMA=public

# Redis
REDIS_URL=redis://localhost:6379/2

# JWT Authentication
JWT_SECRET=change-me-to-django-secret-key
JWT_ALGORITHM=HS256
JWT_ISSUER=htqweb-auth

# Service Configuration
SERVICE_NAME=task-service
SERVICE_PORT=8007
SERVICE_ENV=development
API_PREFIX=/api/tasks/v1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
