# ─── Service Identity ───────────────────────────────────────────────────────
SERVICE_NAME=__service_name__
SERVICE_PORT=8001
SERVICE_ENV=development

# ─── JWT Authentication ─────────────────────────────────────────────────────
# Must match the JWT secret used by Django (SimpleJWT)
JWT_SECRET=change-me-to-django-secret-key
JWT_ALGORITHM=HS256
JWT_ISSUER=htqweb-auth

# ─── Database ───────────────────────────────────────────────────────────────
# Connect via PgBouncer (transaction mode)
DB_HOST=pgbouncer
DB_PORT=5432
DB_NAME=htqweb
DB_USER=htqweb
DB_PASSWORD=change-me
# Schema isolation (each service owns its schema)
DB_SCHEMA=__service_name__

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Observability ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=__service_name__
LOG_LEVEL=INFO

# ─── Circuit Breaker ───────────────────────────────────────────────────────
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT=30
CIRCUIT_HALF_OPEN_REQUESTS=2

# ─── Legacy Django Fallback (for migration period) ─────────────────────────
LEGACY_BACKEND_URL=http://backend:8000
