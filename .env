# SFU / WebRTC
# Your LAN or public IP — mediasoup puts this into SDP so remote peers know where to send RTP.
# For local dev: use your LAN IP (run ipconfig to find it).
# For production: use your public IP or domain (e.g. 203.0.113.10).
WEBRTC_ANNOUNCED_IP=192.168.2.54

# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.2.54,0.0.0.0

# Database (Postgres)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=htqweb
DB_USER=htqweb
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=55432

# Cache — use in-memory for local dev; docker-compose overrides to Redis for containers
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=unique-snowflake

# CORS
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://localhost:3000,http://127.0.0.1:3000,https://127.0.0.1:3000,http://192.168.2.54:3000,https://192.168.2.54:3000,http://localhost,http://127.0.0.1,http://192.168.2.54

